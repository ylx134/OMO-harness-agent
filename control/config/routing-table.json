{
  "routes": {
    "J-L1": {
      "task_type": "判断型",
      "description": "the user mainly wants a conclusion, comparison, explanation, or review",
      "flow_tier": "轻流程",
      "skill_stack": ["check"],
      "manager_requirements": ["acceptance-manager"],
      "capability_requirements": [],
      "probe_requirements": ["artifact-probe-agent"],
      "startup_files": ["task.md"],
      "deliverables": ["answer", "acceptance-report.md"],
      "anti_shallow_bar": "do not pretend a decision task is complete just because a guess sounds plausible",
      "execution_mode": {
        "multi_agent": false,
        "single_thread_allowed": true,
        "requires_contract_negotiation": false
      },
      "scoring_config": null
    },
    "F-M1": {
      "task_type": "修复型",
      "description": "something already broken must stop failing",
      "flow_tier": "中流程",
      "skill_stack": ["drive", "check"],
      "manager_requirements": ["planning-manager", "execution-manager", "acceptance-manager"],
      "capability_requirements": ["shell-agent", "code-agent", "evidence-agent"],
      "probe_requirements": ["regression-probe-agent", "artifact-probe-agent"],
      "startup_files": ["task.md", "working-memory.md", "round-contract.md", "orchestration-status.md"],
      "deliverables": ["round-contract.md", "execution-status.md", "evidence-ledger.md", "acceptance-report.md"],
      "anti_shallow_bar": "main failure path and one nearby regression check are both required",
      "execution_mode": {
        "multi_agent": true,
        "single_thread_allowed": true,
        "requires_contract_negotiation": true
      },
      "scoring_config": {
        "weights": { "产品深度": 0.20, "功能完整性": 0.40, "视觉设计": 0.05, "代码质量": 0.35 },
        "thresholds": { "产品深度": 7, "功能完整性": 8, "视觉设计": 3, "代码质量": 7 },
        "required_rubric": "backend-logic.md",
        "pass_score": 7.0
      }
    },
    "C-M1": {
      "task_type": "改造型",
      "description": "a bounded capability inside an existing system must change",
      "flow_tier": "中流程",
      "skill_stack": ["plan", "drive", "check"],
      "manager_requirements": ["planning-manager", "execution-manager", "acceptance-manager"],
      "capability_requirements": ["docs-agent", "code-agent", "shell-agent", "evidence-agent"],
      "probe_requirements": ["regression-probe-agent", "artifact-probe-agent"],
      "startup_files": ["task.md", "capability-map.md", "gap-analysis.md", "working-memory.md", "round-contract.md", "orchestration-status.md"],
      "deliverables": ["task.md", "round-contract.md", "execution-status.md", "evidence-ledger.md", "acceptance-report.md"],
      "anti_shallow_bar": "do not count visible output alone as progress; the named gap must shrink",
      "execution_mode": {
        "multi_agent": true,
        "single_thread_allowed": true,
        "requires_contract_negotiation": true
      },
      "scoring_config": {
        "weights": { "产品深度": 0.25, "功能完整性": 0.35, "视觉设计": 0.10, "代码质量": 0.30 },
        "thresholds": { "产品深度": 7, "功能完整性": 8, "视觉设计": 4, "代码质量": 7 },
        "required_rubric": "refactoring.md",
        "pass_score": 7.0
      }
    },
    "A-M1": {
      "task_type": "能力型",
      "description": "the real job is to make the system truly able to do something deeper or less visible",
      "flow_tier": "中流程",
      "skill_stack": ["capability-planner", "plan", "drive", "check"],
      "manager_requirements": ["capability-planner", "planning-manager", "execution-manager", "acceptance-manager"],
      "capability_requirements": ["docs-agent", "shell-agent", "code-agent", "evidence-agent"],
      "probe_requirements": ["api-probe-agent", "regression-probe-agent", "artifact-probe-agent"],
      "startup_files": ["task.md", "baseline-source.md", "capability-map.md", "gap-analysis.md", "quality-guardrails.md", "working-memory.md", "round-contract.md", "orchestration-status.md"],
      "deliverables": ["baseline-source.md", "capability-map.md", "gap-analysis.md", "task.md", "round-contract.md", "execution-status.md", "evidence-ledger.md", "acceptance-report.md"],
      "anti_shallow_bar": "do not accept a shell that only looks complete; hidden rule or deeper ability must be proved",
      "execution_mode": {
        "multi_agent": true,
        "single_thread_allowed": true,
        "requires_contract_negotiation": true
      },
      "scoring_config": {
        "weights": { "产品深度": 0.30, "功能完整性": 0.35, "视觉设计": 0.05, "代码质量": 0.30 },
        "thresholds": { "产品深度": 7, "功能完整性": 8, "视觉设计": 3, "代码质量": 7 },
        "required_rubric": "backend-logic.md",
        "pass_score": 7.0
      }
    },
    "P-H1": {
      "task_type": "产品型",
      "description": "the job is to define or build a wider product or subsystem surface",
      "flow_tier": "重流程",
      "skill_stack": ["feature-planner", "plan", "drive", "check"],
      "manager_requirements": ["feature-planner", "planning-manager", "execution-manager", "acceptance-manager"],
      "capability_requirements": ["docs-agent", "browser-agent", "code-agent", "shell-agent", "evidence-agent"],
      "probe_requirements": ["ui-probe-agent", "regression-probe-agent", "artifact-probe-agent"],
      "startup_files": ["task.md", "product-spec.md", "features.json", "features-summary.md", "baseline-source.md", "gap-analysis.md", "working-memory.md", "round-contract.md", "orchestration-status.md"],
      "deliverables": ["product-spec.md", "features.json", "features-summary.md", "task.md", "round-contract.md", "execution-status.md", "evidence-ledger.md", "acceptance-report.md"],
      "anti_shallow_bar": "do not accept minimum-only slices when the product promise or release bar says fuller depth is required",
      "execution_mode": {
        "multi_agent": true,
        "single_thread_allowed": false,
        "requires_contract_negotiation": true
      },
      "scoring_config": {
        "weights": { "产品深度": 0.30, "功能完整性": 0.30, "视觉设计": 0.20, "代码质量": 0.20 },
        "thresholds": { "产品深度": 7, "功能完整性": 8, "视觉设计": 6, "代码质量": 7 },
        "required_rubric": "frontend-design.md",
        "pass_score": 7.0
      }
    }
  },
  "category_mapping": {
    "判断型": "quick",
    "修复型": "deep",
    "改造型": "deep",
    "能力型": "ultrabrain",
    "产品型": "visual-engineering"
  }
}
