{
  "name": "omo-harness-plugin",
  "version": "0.1.0",
  "description": "Runtime orchestration plugin for the OMO managed-agents harness",
  "type": "module",
  "main": "./index.js",
  "scripts": {
    "build": "node ./scripts/sync-routing-table.mjs && tsc -p tsconfig.build.json",
    "pretest": "npm run build",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "config",
    "dist",
    "index.js",
    "README.md"
  ],
  "exports": {
    ".": "./index.js"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^6.0.3"
  }
}
