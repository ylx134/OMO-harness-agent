{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omo-harness.dev/schemas/features.schema.json",
  "title": "Feature List",
  "description": "Schema for the features.json file generated by feature-planner. Enforces immutable structure where only 'passes' field may change after generation.",
  "type": "object",
  "required": ["features"],
  "properties": {
    "features": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "category",
          "priority",
          "complexity",
          "dependencies",
          "acceptance_criteria",
          "verification_method",
          "verification_steps",
          "passes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F\\d{3}$",
            "description": "Feature ID in format F001, F002, etc."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"]
          },
          "complexity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "verification_method": {
            "type": "string",
            "enum": ["e2e_browser", "unit_test", "api_test", "manual", "visual_check", "integration_test", "cli_test"]
          },
          "verification_steps": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "journey_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "state_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "passes": {
            "type": "boolean",
            "description": "THE ONLY MUTABLE FIELD. May be changed from false to true after end-to-end verification."
          }
        }
      }
    }
  }
}
